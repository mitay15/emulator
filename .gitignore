# --- Python cache ---
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Virtual environments ---
venv/
.env

# --- IDE / Editor ---
.vscode/
.idea/

# --- Test / lint caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Build artifacts ---
*.egg-info/
dist/
build/

# --- OS-specific ---
.DS_Store
Thumbs.db

# --- Tools output ---
tree.txt
structure.txt

# --- Remove accidental files ---
get-pip.py

# ============================================================
# PROJECT-SPECIFIC IGNORE RULES
# ============================================================

# --- Ignore ALL generated data ---
data/*

# --- Keep folder structure only ---
!data/.gitkeep
!data/cache/.gitkeep
!data/reports/.gitkeep
!data/clean/.gitkeep
!data/logs/.gitkeep
!data/inputs_before_algo_block/.gitkeep

# --- Ignore contents of all data subfolders ---
data/cache/*
data/reports/*
data/clean/*
data/logs/*
data/inputs_before_algo_block/*

# --- But keep .gitkeep inside each folder ---
!data/cache/.gitkeep
!data/reports/.gitkeep
!data/clean/.gitkeep
!data/logs/.gitkeep
!data/inputs_before_algo_block/.gitkeep

# ============================================================
# END
# ============================================================
