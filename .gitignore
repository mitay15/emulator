# --- Python cache ---
__pycache__/
*.pyc
*.pyo
*.pyd

# --- Virtual environments ---
venv/
.env

# --- IDE / Editor ---
.vscode/
.idea/

# --- Test / lint caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Build artifacts ---
*.egg-info/
dist/
build/

# --- Logs, dumps, debug output (only generated ones) ---
# Не игнорируем все .log/.zip глобально — только в сгенерированных папках
# *.log
# *.zip

# --- Generated data files (only generated folders) ---
# Не игнорируем все .json глобально
# *.json
# *.csv
# *.html
# *.png

# --- Project-specific generated folders ---
data/reports/
project_dump/
debug_bundle_*/

# Keep folder structure but ignore contents of generated cache
data/cache/*
!data/cache/.gitkeep

# Если вы НЕ хотите хранить локальные логи в корне, указывайте конкретную папку.
# Не игнорируем aaps_emulator/data/logs по умолчанию — если хотите игнорировать, раскомментируйте:
# aaps_emulator/data/logs/*
# !aaps_emulator/data/logs/.gitkeep

# --- Tools output ---
tree.txt

# --- OS-specific ---
.DS_Store
Thumbs.db
